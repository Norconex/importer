<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE xml>
<Configuration status="WARN" name="Norconex Importer">
  <Appenders>
    <Console name="Console" target="SYSTEM_OUT">
      <PatternLayout pattern="%d{HH:mm:ss.SSS} [%t] %-5level %logger{36} - %msg%n"/>
    </Console>
  </Appenders>
  <Loggers>

    <Root level="INFO">
      <AppenderRef ref="Console"/>
    </Root>

    <Logger name="com.norconex.importer" level="INFO" additivity="false">
      <AppenderRef ref="Console"/>
    </Logger>
    <Logger name="com.norconex.commons.lang" level="WARN" additivity="false">
      <AppenderRef ref="Console"/>
    </Logger>
    <Logger name="org.apache" level="WARN" additivity="false">
      <AppenderRef ref="Console"/>
    </Logger>
    <Logger name="ImporterEvent" level="WARN" additivity="false">
      <AppenderRef ref="Console"/>
    </Logger>
    
    <!-- To get rid of useless errors from dependencies: -->
    <Logger name="org.apache.pdfbox.jbig2.JBIG2Globals" level="OFF" additivity="false">
      <AppenderRef ref="Console"/>
    </Logger>
    <!--
      POI 5.x (bundled with Tika 3.x) switched from its own NullLogger (the default
      in POI 3.x / Tika 1.x, which silently discarded all log output) to Log4j2 via
      PoiLogManager. As a result, pre-existing ArrayIndexOutOfBoundsExceptions thrown
      inside Chunk.processCommands() when parsing legacy .vsd (HDGF) files now surface
      as ERROR log entries, along with related WARN noise from other POI packages.
      POI catches them internally and continues, so parsing still succeeds.
      There is nothing to fix on our end; suppress the noise here.
    -->
    <Logger name="org.apache.poi.hdgf" level="OFF" additivity="false">
      <AppenderRef ref="Console"/>
    </Logger>
    <Logger name="org.apache.poi.hpsf" level="OFF" additivity="false">
      <AppenderRef ref="Console"/>
    </Logger>
    <Logger name="org.apache.poi.hslf" level="OFF" additivity="false">
      <AppenderRef ref="Console"/>
    </Logger>

  </Loggers>
</Configuration>
